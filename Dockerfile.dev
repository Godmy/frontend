# Development Dockerfile with hot-reload

FROM node:20-alpine

WORKDIR /app

# Enable Corepack and use Yarn 4 (Berry)
RUN corepack enable && corepack prepare yarn@4.11.0 --activate

# Reduce flaky registry timeouts inside Docker
RUN yarn config set -H npmRegistryServer "https://registry.npmjs.org" \
 && yarn config set -H httpTimeout 600000 \
 && yarn config set -H httpRetry 5

# Copy package files
COPY package.json yarn.lock ./

# Install all dependencies (including dev dependencies)
RUN yarn install --immutable

# Copy source code
COPY . .

# Expose dev server port
EXPOSE 5173

# Start development server
CMD ["yarn", "dev", "--host", "0.0.0.0"]
