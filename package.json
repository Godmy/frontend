{
    "name": "@vibe-management-pro/frontend-template",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "svelte-kit sync && vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync && (houdini generate || echo '')",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "test:unit": "vitest",
        "test": "yarn run test:unit --run && yarn run test:e2e",
        "test:e2e": "playwright test",
        "generate": "houdini generate",
        "generate:watch": "houdini generate --watch",
        "generate:pull": "houdini generate --pull-schema",
        "houdini": "houdini",
        "prebuild": "houdini generate"
    },
    "devDependencies": {
        "@eslint/compat": "2.1.0",
        "@eslint/js": "10.0.1",
        "@playwright/test": "1.61.0",
        "@sveltejs/adapter-node": "5.5.4",
        "@sveltejs/kit": "2.66.0",
        "@sveltejs/vite-plugin-svelte": "7.1.2",
        "@testing-library/svelte": "5.4.0",
        "@types/node": "26.0.0",
        "@vitest/browser": "4.1.9",
        "@vitest/coverage-v8": "4.1.9",
        "eslint": "10.5.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-svelte": "3.19.0",
        "globals": "17.6.0",
        "houdini": "2.0.0-next.41",
        "houdini-svelte": "3.0.0-next.35",
        "playwright": "1.61.0",
        "postcss": "8.5.15",
        "prettier": "3.8.4",
        "prettier-plugin-svelte": "4.1.1",
        "svelte": "5.56.3",
        "svelte-check": "4.6.0",
        "typescript": "5.9.2",
        "typescript-eslint": "8.61.1",
        "vite": "8.0.16",
        "vitest": "4.1.9",
        "vitest-browser-svelte": "2.1.1"
    },
    "dependencies": {
        "graphql": "16.14.2",
        "stylist-svelte": "portal:../stylist-svelte"
    }
}
